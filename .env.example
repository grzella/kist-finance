SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
PORT=8321

# --- All of the below are optional; the app runs fully offline without them. ---

# Local AI (llama.cpp / LM Studio / Ollama — OpenAI-compatible). See README > Local AI.
# LOCAL_LLM_URL=http://127.0.0.1:8080/v1
# LOCAL_LLM_KEY=<the --api-key you started the server with>

# Cloud AI (optional, opt-in in Control Center; sends prompts to Anthropic).
# ANTHROPIC_API_KEY=<your-anthropic-key>

# Semantic RAG (optional embedding server). See README > Local RAG.
# LOCAL_EMBED_URL=http://127.0.0.1:8081/v1
# LOCAL_EMBED_MODEL=<optional-model-id>
# LOCAL_EMBED_KEY=<optional-key>

# Backups: set to encrypt snapshots at rest (needs `pip install cryptography`).
# BACKUP_KEY=<any-passphrase>

# Where data lives. Default: outside the repo (see README). Override here if you want.
# FINANCE_PROJECT_DIR=/path/to/a/folder
